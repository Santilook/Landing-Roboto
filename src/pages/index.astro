---
import Inicio from "../components/sections/inicio.astro";
import Modelos from "../components/sections/modelos.astro";
import Nosotros from "../components/sections/nosotros.astro";
import Layout from "../layouts/Layout.astro";
import Contacto from "../components/sections/contacto.astro";
import Footer from "../components/common/footer.astro";
---

<Layout>
  <div class="relative w-full h-screen">
    <!-- Fondo futurista animado para mobile/tablet (se oculta en desktop) -->
    <div class="spline-fallback" aria-hidden="true">
      <div class="fallback-grid"></div>
      <div class="fallback-orb fallback-orb-1"></div>
      <div class="fallback-orb fallback-orb-2"></div>
      <div class="fallback-orb fallback-orb-3"></div>
    </div>

    <!-- Spline 3D solo se carga en desktop via JS -->
    <div id="spline-container" class="hidden lg:block" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:0;"></div>

    <Inicio />
    <Modelos />
    <Nosotros />
    <Contacto />
    <Footer />
  </div>

  <!-- Spline se carga solo en desktop -->
  <script>
    if (window.innerWidth >= 1024) {
      const container = document.getElementById('spline-container');
      if (container) {
        const viewer = document.createElement('spline-viewer');
        viewer.setAttribute('url', 'https://prod.spline.design/gkWyDDcDU9ZRPfw5/scene.splinecode');
        viewer.style.cssText = 'width:100%;height:100%;';
        container.appendChild(viewer);

        const script = document.createElement('script');
        script.type = 'module';
        script.src = 'https://unpkg.com/@splinetool/viewer@1.10.85/build/spline-viewer.js';
        document.head.appendChild(script);
      }
    }
  </script>
</Layout>

<style is:global>
  /* Animación de entrada inicial solo para desktop */
  @media (min-width: 1024px) {
    .initial-fade-in {
      opacity: 0;
      animation: customFadeIn 3s ease-out 3s both;
    }
  }

  @keyframes customFadeIn {
    0% {
      opacity: 0;
      transform: translateY(100px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Fondo futurista para mobile/tablet ── */
  .spline-fallback {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    background: linear-gradient(
      135deg,
      #e8edf2 0%,
      #dce4ec 25%,
      #d0dbe6 50%,
      #c5d3e0 75%,
      #e0e8f0 100%
    );
    overflow: hidden;
  }

  /* Cuadrícula tipo HUD más visible */
  .fallback-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(6, 182, 212, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(6, 182, 212, 0.15) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridPulse 6s ease-in-out infinite;
  }

  /* Orbes de luz animados — más grandes y visibles */
  .fallback-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.8;
    will-change: transform;
  }

  .fallback-orb-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.5), transparent 70%);
    top: -5%;
    right: -15%;
    animation: orbFloat1 10s ease-in-out infinite;
  }

  .fallback-orb-2 {
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.4), transparent 70%);
    bottom: -10%;
    left: -15%;
    animation: orbFloat2 13s ease-in-out infinite;
  }

  .fallback-orb-3 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.35), transparent 70%);
    top: 40%;
    left: 30%;
    animation: orbFloat3 8s ease-in-out infinite;
  }

  @keyframes gridPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @keyframes orbFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-60px, 50px) scale(1.15); }
    66% { transform: translate(30px, -30px) scale(0.9); }
  }

  @keyframes orbFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(50px, -60px) scale(1.2); }
    66% { transform: translate(-30px, 40px) scale(0.85); }
  }

  @keyframes orbFloat3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-50px, -50px) scale(1.3); }
  }

  /* En desktop el fondo animado se oculta (Spline toma su lugar) */
  @media (min-width: 1024px) {
    .spline-fallback {
      display: none;
    }
  }
</style>
