---
import { db, Reservas } from "astro:db";
import { desc} from "astro:db";
import Layout from "@/layouts/Layout.astro";

let todasLasReservas = [];
let errorMensaje = "";
try {
  todasLasReservas = await db.select().from(Reservas).orderBy(desc(Reservas.fecha));
} catch (e) {
  console.error(e);
  errorMensaje = "No se pudieron cargar las reservas.";
}
// Formateador de fechas para que se vean bonitas
const formatearFecha = (fechaOriginal: Date) => {
  return new Intl.DateTimeFormat('es-ES', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit'
  }).format(new Date(fechaOriginal));
};

---

<Layout title="ROBOTO | Panel de Administrador" description="Panel de control interno">
  <main class="min-h-screen pt-12 pb-16 px-4 md:px-8 text-white relative overflow-hidden">

    <div class="admin-bg" aria-hidden="true">
      <div class="admin-grid"></div>
      <div class="admin-orb admin-orb-1"></div>
      <div class="admin-orb admin-orb-2"></div>
      <div class="admin-orb admin-orb-3"></div>
    </div>
    
      
      <!-- Encabezado del Panel -->
      <header class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-gray-800 pb-6">
        <div>
          <span class="text-cyan-400 drop-shadow-[0_0_15px_rgba(6,182,212,0.3)] font-mono text-sm tracking-widest uppercase font-bold block">Acceso Restringido</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-black mb-2 uppercase">Control de reservas</h1>
          <p class="text-gray-400">Sistema de gestión de reservas y solicitudes.</p>
        </div>
        <div class="bg-black/50 border border-gray-800 rounded-lg px-4 py-3 flex items-center gap-3">
          <div class="h-3 w-3 rounded-full bg-emerald-500 animate-pulse"></div>
          <span class="text-gray-300 font-mono text-sm">Sistema en Línea</span>
        </div>
      </header>
      <!-- Manejo de Errores o Estado Vacío -->
      {errorMensaje && (
        <div class="bg-red-900/20 border border-red-500/50 text-red-400 p-4 rounded-lg mb-8">
          {errorMensaje}
        </div>
      )}
      {todasLasReservas.length === 0 && !errorMensaje ? (
        <div class="text-center py-20 bg-sky-100 border-b border-[#25D1F4] rounded-2xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-gray-700 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <p class="text-xl text-gray-400 font-medium">No hay reservas registradas en la base de datos.</p>
          <p class="text-gray-500 mt-2">Los nuevos pedidos aparecerán aquí automáticamente.</p>
        </div>
      ) : (
        <div class="border border-[#25D1F4] rounded-2xl overflow-hidden shadow-2xl">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-sky-100 border-b border-[#25D1F4]">
                  <th class="py-4 px-6 text-xs md:text-md lg:text-lg font-semibold text-[#25D1F4] uppercase tracking-wider">Fecha / ID</th>
                  <th class="py-4 px-6 text-xs md:text-md lg:text-lg font-semibold text-[#25D1F4] uppercase tracking-wider">Cliente</th>
                  <th class="py-4 px-6 text-xs md:text-md lg:text-lg font-semibold text-[#25D1F4] uppercase tracking-wider">Modelo Solicitado</th>
                  <th class="py-4 px-6 text-xs md:text-md lg:text-lg font-semibold text-[#25D1F4] uppercase tracking-wider">Notas</th>
                </tr>
              </thead>
              <tbody class="bg-[#F8FAFC] divide-y">
                {todasLasReservas.map((reserva) => (
                  <tr class="hover:bg-gray-800/30 transition-colors">
                    
                    {/* Fecha y ID Oculto */}
                    <td class="py-4 px-6 whitespace-nowrap">
                      <div class="text-sm md:text-md lg:text-lg font-medium text-emerald-400">{formatearFecha(reserva.fecha)}</div>
                      <div class="text-[10px] text-gray-600 font-mono mt-1" title={reserva.id}>
                        {reserva.id ? reserva.id.substring(0, 8) + '...' : 'ID_N/A'}
                      </div>
                    </td>
                    {/* Cliente (Nombre e Info) */}
                    <td class="py-4 px-6">
                      <div class="text-sm md:text-md lg:text-lg font-medium text-black">{reserva.nombre}</div>
                      <div class="text-sm md:text-md lg:text-lg text-gray-400 flex items-center gap-1 mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        <a href={`mailto:${reserva.email}`} class="hover:text-emerald-400 transition-colors">{reserva.email}</a>
                      </div>
                    </td>
                    {/* Modelo (Badge) */}
                    <td class="py-4 px-6 whitespace-nowrap">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                        {reserva.modelo}
                      </span>
                    </td>
                    {/* Mensaje */}
                    <td class="py-4 px-6 max-w-xs">
                      <p class="text-sm md:text-md lg:text-lg text-black truncate" title={reserva.mensaje}>
                        {reserva.mensaje || <span class="text-gray-600 italic">Sin comentarios</span>}
                      </p>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
      
      <div class="mt-8 text-center">
         <a href="/" class="text-sm md:text-md lg:text-lg text-gray-500 hover:text-[#25D1F4] transition-colors border-b border-transparent hover:border-[#25D1F4] pb-1">« Volver al sitio público</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* ── Fondo futurista para admin (siempre visible) ── */
  .admin-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    background: linear-gradient(
      135deg,
      #e8edf2 0%,
      #dce4ec 25%,
      #d0dbe6 50%,
      #c5d3e0 75%,
      #e0e8f0 100%
    );
    overflow: hidden;
  }

  /* Cuadrícula tipo HUD más visible */
  .admin-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(6, 182, 212, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(6, 182, 212, 0.15) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridPulse 6s ease-in-out infinite;
  }

  /* Orbes de luz animados — más grandes y visibles */
  .admin-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.8;
    will-change: transform;
  }

  .admin-orb-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.5), transparent 70%);
    top: -5%;
    right: -15%;
    animation: orbFloat1 10s ease-in-out infinite;
  }

  .admin-orb-2 {
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.4), transparent 70%);
    bottom: -10%;
    left: -15%;
    animation: orbFloat2 13s ease-in-out infinite;
  }

  .admin-orb-3 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.35), transparent 70%);
    top: 40%;
    left: 30%;
    animation: orbFloat3 8s ease-in-out infinite;
  }

  @keyframes gridPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @keyframes orbFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-60px, 50px) scale(1.15); }
    66% { transform: translate(30px, -30px) scale(0.9); }
  }

  @keyframes orbFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(50px, -60px) scale(1.2); }
    66% { transform: translate(-30px, 40px) scale(0.85); }
  }

  @keyframes orbFloat3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-50px, -50px) scale(1.3); }
  }
</style>