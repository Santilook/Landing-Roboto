---
import Layout from "@/layouts/Layout.astro";

const error = Astro.url.searchParams.get('error');
---

<Layout title="ROBOTO | Acceso de Seguridad" description="Panel de control interno">
  <main class="min-h-screen flex items-center justify-center relative overflow-hidden px-4 py-20">
    
    <!-- Fondo futurista (Igual al Admin y Landing) -->
    <div class="admin-bg" aria-hidden="true">
      <div class="admin-grid"></div>
      <div class="admin-orb admin-orb-1"></div>
      <div class="admin-orb admin-orb-2"></div>
      <div class="admin-orb admin-orb-3"></div>
    </div>

    <div class="w-full max-w-md relative z-10">
      <!-- Logo/Icono -->
      <div class="flex justify-center mb-8">
        <div class="w-20 h-20 rounded-2xl bg-white/80 border border-cyan-200 flex items-center justify-center text-cyan-500 shadow-xl backdrop-blur-md">
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
      </div>

      <!-- Tarjeta de Login -->
      <div class="bg-white/90 backdrop-blur-2xl border border-white rounded-3xl p-8 lg:p-10 shadow-[0_20px_60px_rgba(0,0,0,0.1)]">
        <div class="text-center mb-8">
          <h1 class="font-[Orbitron] text-2xl font-bold text-gray-900 tracking-widest uppercase mb-2">Protocolo Alpha</h1>
          <p class="font-[Space_Mono] text-[10px] text-cyan-600 tracking-[4px] uppercase font-bold opacity-70">Verificación de Identidad</p>
        </div>

        <form action="/api/auth" method="POST" class="space-y-6">
          <div class="space-y-2">
            <label for="password" class="font-[Orbitron] text-cyan-600 text-[10px] font-black tracking-[3px] uppercase block ml-1">Clave de Acceso</label>
            <div class="relative">
              <input 
                type="password" 
                id="password" 
                name="password" 
                required
                placeholder="••••••••••••"
                class="w-full bg-gray-50 border border-gray-100 rounded-xl py-4 px-5 text-gray-900 font-[Space_Mono] focus:outline-none focus:border-cyan-400 focus:bg-white transition-all placeholder:text-gray-300"
              />
              <div class="absolute right-4 top-1/2 -translate-y-1/2 text-cyan-400 opacity-30">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
            </div>
          </div>

          {error && (
            <div class="bg-red-50 border border-red-100 text-red-500 text-[10px] font-[Space_Mono] p-3 rounded-xl text-center uppercase tracking-widest">
              Acceso Denegado: Credenciales Inválidas
            </div>
          )}

          <button 
            type="submit"
            class="w-full bg-cyan-500 text-white font-[Orbitron] font-bold py-4 rounded-xl hover:bg-cyan-400 transition-all shadow-[0_10px_30px_rgba(6,182,212,0.3)] hover:shadow-[0_15px_40px_rgba(6,182,212,0.4)] active:scale-[0.98] uppercase tracking-widest text-sm cursor-pointer"
          >
            Iniciar Enlace
          </button>
        </form>

        <div class="mt-8 text-center">
          <a href="/" class="font-[Space_Mono] text-[10px] text-gray-400 hover:text-cyan-600 transition-colors uppercase tracking-widest">
            « Retornar a Interfaz Pública
          </a>
        </div>
      </div>

      <!-- Decoración HUD -->
      <div class="mt-8 flex justify-between items-center px-4">
        <div class="h-[1px] flex-1 bg-gradient-to-r from-transparent to-gray-200"></div>
        <div class="mx-4 font-[Space_Mono] text-[9px] text-gray-400 uppercase tracking-[2px]">Encripción AES-256 Activa</div>
        <div class="h-[1px] flex-1 bg-gradient-to-l from-transparent to-gray-200"></div>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Copiamos los estilos del fondo del admin para que sea idéntico */
  .admin-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    background: linear-gradient(135deg, #e8edf2 0%, #dce4ec 25%, #d0dbe6 50%, #c5d3e0 75%, #e0e8f0 100%);
    overflow: hidden;
  }
  .admin-grid {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(6, 182, 212, 0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.15) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridPulse 6s ease-in-out infinite;
  }
  .admin-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.8;
    will-change: transform;
  }
  .admin-orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(6, 182, 212, 0.5), transparent 70%); top: -5%; right: -15%; animation: orbFloat1 10s ease-in-out infinite; }
  .admin-orb-2 { width: 450px; height: 450px; background: radial-gradient(circle, rgba(14, 165, 233, 0.4), transparent 70%); bottom: -10%; left: -15%; animation: orbFloat2 13s ease-in-out infinite; }
  .admin-orb-3 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(56, 189, 248, 0.35), transparent 70%); top: 40%; left: 30%; animation: orbFloat3 8s ease-in-out infinite; }

  @keyframes gridPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  @keyframes orbFloat1 { 0%, 100% { transform: translate(0, 0) scale(1); } 33% { transform: translate(-60px, 50px) scale(1.15); } 66% { transform: translate(30px, -30px) scale(0.9); } }
  @keyframes orbFloat2 { 0%, 100% { transform: translate(0, 0) scale(1); } 33% { transform: translate(50px, -60px) scale(1.2); } 66% { transform: translate(-30px, 40px) scale(0.85); } }
  @keyframes orbFloat3 { 0%, 100% { transform: translate(0, 0) scale(1); } 50% { transform: translate(-50px, -50px) scale(1.3); } }

  input:-webkit-autofill {
    -webkit-text-fill-color: #111827;
    -webkit-box-shadow: 0 0 0px 1000px #f9fafb inset;
  }
</style>
