---

---

<footer
  class="w-full relative z-30 bg-white/70 backdrop-blur-md border-t border-white/60 shadow-[0_-10px_30px_rgba(0,0,0,0.05)] mt-20"
>
  <div
    class="max-w-[1300px] mx-auto px-6 lg:px-10 py-8 lg:py-12 flex flex-col items-center justify-between gap-6 md:flex-row"
  >
    <!-- Logo / Nombre -->
    <div class="flex items-center gap-3">
      <div
        class="w-8 h-8 rounded bg-[#e0fcff] flex items-center justify-center border border-[#00e5ff]/30 text-[#00e5ff]"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      <div>
        <h2
          class="font-[Orbitron] text-lg font-bold text-gray-900 tracking-wider m-0 leading-none flex items-center gap-2"
        >
          <img
            src="/logo-R.svg"
            alt="Logo"
            class="w-5 h-5"
            style="filter: brightness(0);"
          />
          OBOTO
        </h2>
        <p
          class="font-[Space_Mono] text-[10px] text-[#00e5ff] tracking-widest uppercase mt-1 font-bold"
        >
          SISTEMA EN LÍNEA
        </p>
      </div>
    </div>

    <!-- Enlaces / Info -->
    <div
      class="flex flex-wrap justify-center gap-6 lg:gap-10 font-[Space_Mono] text-xs font-semibold text-gray-500 tracking-wider"
    >
      <a href="#" class="hover:text-[#00e5ff] transition-colors duration-300"
        >MODELOS</a
      >
      <a href="#" class="hover:text-[#00e5ff] transition-colors duration-300"
        >NOSOTROS</a
      >
      <a href="#" class="hover:text-[#00e5ff] transition-colors duration-300"
        >SOPORTE</a
      >
      <a href="#" class="hover:text-[#00e5ff] transition-colors duration-300"
        >PRIVACIDAD</a
      >
    </div>

    <!-- Copyright -->
    <div class="text-center md:text-right">
      <p class="font-[Space_Mono] text-[10px] text-gray-400 tracking-widest">
        © 2026 NEXUS ROBOTICS.
      </p>
      <p
        class="font-[Space_Mono] text-[10px] text-gray-400 tracking-widest mt-1"
      >
        TODOS LOS DERECHOS RESERVADOS.
      </p>
    </div>
  </div>

  <!-- Linea decorativa inferior -->
  <div
    class="w-full h-1 bg-gradient-to-r from-transparent via-[#00e5ff] to-transparent opacity-50"
  >
  </div>
</footer>
