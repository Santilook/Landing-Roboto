---
import ContadorAnimado from "./extras/ContadorAnimado.jsx";
---

<header class="">
  <div
    class="grid grid-cols-5 grid-rows-5 z-10 relative h-full"
    style="pointer-events: none;"
  >
    <div class="col-span-2">
      <div class="flex items-center gap-3 mx-20 my-10">
        <span class="bg-[#00e5ff] py-7 px-2 rounded-full"></span>
        <h1 class="text-6xl font-bold">ROBOTO</h1>
        <span class="absolute right-12" style="pointer-events: visible;">
          <a href="https://github.com/Santilook" target="_blank"
            ><svg
              xmlns="http://www.w3.org/2000/svg"
              width="44"
              height="44"
              viewBox="0 0 24 24"
              ><defs
                ><mask id="SVGcZ81hcNk"
                  ><path
                    fill="#fff"
                    d="M9.5 8c0.83 0 1.5 0.45 1.5 1c0 0.55 -0.67 1 -1.5 1c-0.83 0 -1.5 -0.45 -1.5 -1c0 -0.55 0.67 -1 1.5 -1ZM14.5 8c0.83 0 1.5 0.45 1.5 1c0 0.55 -0.67 1 -1.5 1c-0.83 0 -1.5 -0.45 -1.5 -1c0 -0.55 0.67 -1 1.5 -1Z"
                  ></path><rect width="8" height="4" x="8" y="7"
                    ><animate
                      attributeName="y"
                      dur="9s"
                      keyTimes="0;0.45;0.46;0.54;0.55;1"
                      repeatCount="indefinite"
                      values="7;7;11;11;7;7"></animate></rect
                  ></mask
                ></defs
              ><g
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                ><path
                  stroke-dasharray="32"
                  d="M12 4c1.67 0 2.61 0.4 3 0.5c0.53 -0.43 1.94 -1.5 3.5 -1.5c0.34 1 0.29 2.22 0 3c0.75 1 1 2 1 3.5c0 2.19 -0.48 3.58 -1.5 4.5c-1.02 0.92 -2.11 1.37 -3.5 1.5c0.65 0.54 0.5 1.87 0.5 2.5c0 0.73 0 3 0 3M12 4c-1.67 0 -2.61 0.4 -3 0.5c-0.53 -0.43 -1.94 -1.5 -3.5 -1.5c-0.34 1 -0.29 2.22 0 3c-0.75 1 -1 2 -1 3.5c0 2.19 0.48 3.58 1.5 4.5c1.02 0.92 2.11 1.37 3.5 1.5c-0.65 0.54 -0.5 1.87 -0.5 2.5c0 0.73 0 3 0 3"
                  ><animate
                    fill="freeze"
                    attributeName="stroke-dashoffset"
                    dur="0.6s"
                    values="32;0"></animate></path
                ><path
                  stroke-dasharray="10"
                  stroke-dashoffset="10"
                  d="M9 19c-1.41 0 -2.84 -0.56 -3.69 -1.19c-0.84 -0.62 -1.09 -1.66 -2.31 -2.31"
                  ><animate
                    attributeName="d"
                    dur="3s"
                    keyTimes="0;0.5;1"
                    repeatCount="indefinite"
                    values="M9 19c-1.41 0 -2.84 -0.56 -3.69 -1.19c-0.84 -0.62 -1.09 -1.66 -2.31 -2.31;M9 19c-1.41 0 -3 -0.5 -4 -0.5c-0.53 0 -1 0 -2 -0.5;M9 19c-1.41 0 -2.84 -0.56 -3.69 -1.19c-0.84 -0.62 -1.09 -1.66 -2.31 -2.31"
                  ></animate><animate
                    fill="freeze"
                    attributeName="stroke-dashoffset"
                    begin="0.7s"
                    dur="0.2s"
                    to="0"></animate></path
                ></g
              ><path
                fill="currentColor"
                d="M0 0h24v24H0z"
                mask="url(#SVGcZ81hcNk)"></path></svg
            ></a
          ></span
        >
      </div>
    </div>
    <div
      class="col-span-2 row-span-3 col-start-1 row-start-2 items-center justify-center flex"
    >
      <div class="flex flex-col gap-10 mx-20 my-10">
        <h2 class="text-6xl font-bold">Más Allá de la Capacidad Humana.</h2>
        <div class="flex gap-2">
          <span class="bg-[#00e5ff] py-7 px-0.5 rounded-full"></span>
          <p class="text-2xl">
            Presentamos la Serie X. Sistemas humanoides de ingeniería de
            precisión diseñados para la escala industrial y la compañía
            personal. Cada unidad está construida con inteligencia adaptativa,
            permitiéndoles aprender y evolucionar según tus necesidades.
            Experimenta el futuro de la automatización con tecnología que
            redefine los límites de lo posible.
          </p>
        </div>
        <button
          class="bg-[#0f172b] text-white font-bold py-3 px-8 flex items-center gap-2 rounded-full w-fit cursor-pointer hover:scale-105 transition-all duration-300"
          style="pointer-events: visible;"
          >Explora nuestros modelos
          <span
            ><svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              ><path
                fill="currentColor"
                d="M6.4 18L5 16.6L14.6 7H6V5h12v12h-2V8.4z"></path></svg
            ></span
          >
        </button>
      </div>
    </div>
    <!-- contador animado -->
    <ContadorAnimado client:visible />
  </div>
  <div class="col-span-2 col-start-4 row-start-1 mx-20 my-10 relative z-100">
    <nav class="fixed right-13 top-50" style="pointer-events: visible;">
      <ul class="flex flex-col gap-5 text-2xl text-end">
        <li class="flex items-center justify-end gap-5">
          <p class="text-xl text-[#8d9497]">01</p><a
            class="hover:underline"
            href="/">Inicio</a
          >
        </li>
        <li class="flex items-center justify-end gap-5">
          <p class="text-xl text-[#8d9497]">02</p><a
            class="hover:underline"
            href="#modelos">Modelos</a
          >
        </li>
        <li class="flex items-center justify-end gap-5">
          <p class="text-xl text-[#8d9497]">03</p><a
            class="hover:underline"
            href="#nosotros">Nosotros</a
          >
        </li>
        <li class="flex items-center justify-end gap-5">
          <p class="text-xl text-[#8d9497]">04</p><a
            class="hover:underline"
            href="#contacto">Contacto</a
          >
        </li>
      </ul>
    </nav>
    <div
      class="absolute bottom-50 right-30 p-10 rounded-xl border-1 border-[#00e5ff] w-100"
    >
      <div class="flex flex-col gap-5">
        <h2 class="text-2xl font-bold">X-SERIES AONE</h2>
        <p class="text-md">
          Descubre la nueva generación de robots humanoides. El X-SERIES AONE
          combina agilidad suprema con un núcleo cognitivo avanzado. Es capaz de
          integrarse en cualquier entorno para brindar soluciones eficientes y
          asistencia inigualable.
        </p>
        <button
          class="bg-[#00e5ff] rounded-full py-3 px-8 font-bold cursor-pointer hover:scale-105 transition-all duration-300"
          >PRE-COMPRA AHORA</button
        >
      </div>
      <div class="flex justify-between mt-5">
        <p class="text-[#7c8695] text-md">Modelo</p>
        <p class="text-[#00e5ff] text-md">X-SERIES AONE</p>
      </div>
    </div>
  </div>
  <div class="col-start-3 row-start-5">
    <div
      class="flex items-center justify-center bottom-20 relative"
      style="pointer-events: visible;"
    >
      <a href="" class="animate-bounce">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="54"
          height="54"
          viewBox="0 0 24 24"
          ><path
            fill="#00e5ff"
            d="m11.5 13.508l-1.766-1.766q-.14-.14-.334-.14t-.334.14t-.141.348t.14.34l2.389 2.39q.242.241.565.241t.565-.242l2.389-2.388q.14-.134.14-.341t-.14-.348t-.347-.14t-.341.14l-1.766 1.766V9.096q0-.212-.144-.356t-.357-.144t-.365.144t-.153.356zM12.003 21q-1.866 0-3.51-.708q-1.643-.709-2.859-1.924t-1.925-2.856T3 12.003t.709-3.51Q4.417 6.85 5.63 5.634t2.857-1.925T11.997 3t3.51.709q1.643.708 2.859 1.922t1.925 2.857t.709 3.509t-.708 3.51t-1.924 2.859t-2.856 1.925t-3.509.709M12 20q3.35 0 5.675-2.325T20 12t-2.325-5.675T12 4T6.325 6.325T4 12t2.325 5.675T12 20m0-8"
          ></path></svg
        >
      </a>
    </div>
  </div>
</header>
