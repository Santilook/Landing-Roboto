---
import BtnContacto from "./extras/Btn-contacto.astro";
import { Globe } from "./magicui/globe.tsx";

// src/components/contacto.astro
---

<section
  id="contacto"
  class="w-full flex flex-col items-center justify-center px-6 lg:px-10 py-20 box-border relative z-30 pointer-events-none"
>
  <div class="w-full max-w-[1300px] mx-auto">
    <!-- ENCABEZADO -->
    <div class="mb-12">
      <h2
        class="font-[Orbitron] text-[clamp(28px,4vw,40px)] font-bold text-gray-900 m-0 uppercase tracking-wide flex items-center gap-3"
      >
        ESTABLISH <span class="text-[#00e5ff]">UPLINK</span>
      </h2>
      <p
        class="font-[Space_Mono] text-xs lg:text-sm text-gray-500 tracking-[3px] uppercase mt-2 font-semibold"
      >
        Connect with our neural support network
      </p>
    </div>

    <!-- MAIN GRID CONTAINER -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 relative items-stretch">

      <!-- LEFT COLUMN: FORM -->
      <div class="col-span-1 lg:col-span-5 relative z-10">
        <div
          class="relative w-full bg-white/70 backdrop-blur-xl border border-white/60 rounded-tr-lg rounded-bl-lg p-6 lg:p-10 shadow-[0_20px_50px_-10px_rgba(0,0,0,0.15)]"
        >
          <!-- Brackets -->
          <div
            class="absolute -top-[5px] -left-[5px] w-5 h-5 border-t-[3px] border-l-[3px] border-[#00e5ff] rounded-tl-sm pointer-events-none"
          >
          </div>
          <div
            class="absolute -bottom-[5px] -right-[5px] w-5 h-5 border-b-[3px] border-r-[3px] border-[#00e5ff] rounded-br-sm pointer-events-none"
          >
          </div>

          <form class="flex flex-col gap-6">
            <!-- FIELD 1 -->
            <div class="flex flex-col gap-2 pointer-events-auto">
              <label
                class="font-[Orbitron] text-[#00e5ff] text-[10px] font-bold tracking-[2px]"
                >SUBJECT NAME</label
              >
              <div
                class="relative flex items-center bg-[#f0f4f8]/80 rounded-xl overflow-hidden border border-transparent focus-within:border-[#00e5ff]/50 transition-colors"
              >
                <svg
                  class="absolute left-4 w-5 h-5 text-[#00e5ff]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  ></path>
                </svg>
                <input
                  type="text"
                  placeholder="ENTER IDENTIFICATION"
                  class="w-full bg-transparent py-4 pl-12 pr-4 font-[Space_Mono] text-gray-700 text-[13px] sm:text-sm focus:outline-none placeholder-gray-400 font-medium"
                />
              </div>
            </div>

            <!-- FIELD 2 -->
            <div class="flex flex-col gap-2 pointer-events-auto">
              <label
                class="font-[Orbitron] text-[#00e5ff] text-[10px] font-bold tracking-[2px]"
                >NEURAL ID (EMAIL)</label
              >
              <div
                class="relative flex items-center bg-[#f0f4f8]/80 rounded-xl overflow-hidden border border-transparent focus-within:border-[#00e5ff]/50 transition-colors"
              >
                <svg
                  class="absolute left-4 w-5 h-5 text-[#00e5ff]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"
                  ></path>
                </svg>
                <input
                  type="email"
                  placeholder="USER@NETWORK.NEXUS"
                  class="w-full bg-transparent py-4 pl-12 pr-4 font-[Space_Mono] text-gray-700 text-[13px] sm:text-sm focus:outline-none placeholder-gray-400 font-medium"
                />
              </div>
            </div>

            <!-- FIELD 3 -->
            <div class="flex flex-col gap-2 pointer-events-auto">
              <label
                class="font-[Orbitron] text-[#00e5ff] text-[10px] font-bold tracking-[2px]"
                >PROTOCOL TYPE</label
              >
              <div
                class="relative flex items-center bg-[#f0f4f8]/80 rounded-xl overflow-hidden border border-transparent focus-within:border-[#00e5ff]/50 transition-colors"
              >
                <svg
                  class="absolute left-4 w-5 h-5 text-[#00e5ff]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <select
                  class="w-full bg-transparent py-4 pl-12 pr-10 font-[Space_Mono] text-gray-700 text-[13px] sm:text-sm focus:outline-none appearance-none font-bold cursor-pointer"
                >
                  <option value="technical">TECHNICAL INQUIRY</option>
                  <option value="sales">ACQUISITION PROTOCOL</option>
                  <option value="support">SYSTEM DIAGNOSTICS</option>
                </select>
                <!-- Custom drop arrow -->
                <svg
                  class="absolute right-4 w-4 h-4 text-gray-400 pointer-events-none"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 9l-7 7-7-7"></path>
                </svg>
              </div>
            </div>

            <!-- FIELD 4 -->
            <div class="flex flex-col gap-2 pointer-events-auto">
              <label
                class="font-[Orbitron] text-[#00e5ff] text-[10px] font-bold tracking-[2px]"
                >TRANSMISSION DETAILS</label
              >
              <div
                class="relative flex items-start bg-[#f0f4f8]/80 rounded-xl overflow-hidden border border-transparent focus-within:border-[#00e5ff]/50 transition-colors"
              >
                <textarea
                  rows="4"
                  placeholder="INITIALIZE DATA TRANSFER..."
                  class="w-full bg-transparent py-3 px-5 font-[Space_Mono] text-gray-700 text-[13px] sm:text-sm focus:outline-none placeholder-gray-400 resize-none font-medium"
                ></textarea>
              </div>
            </div>

            <!-- SUBMIT BUTTON -->
            <BtnContacto />
          </form>
        </div>
      </div>

      <!-- SPACER COLUMN PARA PANTALLAS GRANDES -->
      <!-- Oculto el spacer en móvil, solo ocupa espacio relativo en layout grid en desktop -->
      <div class="hidden lg:block lg:col-span-3"></div>

      <!-- RIGHT COLUMN: INFO CARDS -->
      <div
        class="col-span-1 lg:col-span-4 flex flex-col gap-5 lg:gap-6 relative z-10 w-full xl:w-[90%] mx-auto lg:mx-0 lg:ml-auto"
      >
        <!-- CARD 1 -->
        <div
          class="relative bg-white/70 backdrop-blur-md rounded-tr-lg rounded-bl-lg p-5 lg:p-6 border border-white/60 shadow-[0_15px_30px_-5px_rgba(0,0,0,0.08)]"
        >
          <div
            class="absolute -top-[3px] -left-[3px] w-4 h-4 border-t-[2px] border-l-[2px] border-[#00e5ff]/80 rounded-tl-sm pointer-events-none"
          >
          </div>
          <div
            class="absolute -bottom-[3px] -right-[3px] w-4 h-4 border-b-[2px] border-r-[2px] border-[#00e5ff]/80 rounded-br-sm pointer-events-none"
          >
          </div>

          <div class="flex items-center gap-4 mb-4">
            <div
              class="w-10 h-10 lg:w-12 lg:h-12 rounded-xl bg-[#e0fcff] flex items-center justify-center text-[#00e5ff] shrink-0"
            >
              <svg
                class="w-5 h-5 lg:w-6 lg:h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3
                class="font-[Orbitron] text-[13px] lg:text-sm font-bold text-gray-900 tracking-wider"
              >
                HQ COORDINATES
              </h3>
              <p
                class="font-[Space_Mono] text-[9px] lg:text-[10px] text-[#00e5ff] tracking-widest uppercase mt-0.5 font-bold"
              >
                GEO-SYNC: 37.7749° N, 122.4194° W
              </p>
            </div>
          </div>
          <!-- Mapa decorativo -->
          <div
            class="w-full h-20 lg:h-50 bg-gray-900 rounded-xl overflow-hidden border border-gray-200 pointer-events-none"
          >
            <div class="relative w-full h-[500px] pointer-events-auto">
              <Globe client:visible />
            </div>
          </div>
        </div>

        <!-- CARD 2 -->
        <div
          class="relative bg-white/70 backdrop-blur-md rounded-tr-lg rounded-bl-lg p-5 lg:p-6 border border-white/60 shadow-[0_15px_30px_-5px_rgba(0,0,0,0.08)]"
        >
          <div
            class="absolute -top-[3px] -left-[3px] w-4 h-4 border-t-[2px] border-l-[2px] border-[#00e5ff]/80 rounded-tl-sm pointer-events-none"
          >
          </div>
          <div
            class="absolute -bottom-[3px] -right-[3px] w-4 h-4 border-b-[2px] border-r-[2px] border-[#00e5ff]/80 rounded-br-sm pointer-events-none"
          >
          </div>

          <div class="flex items-center gap-4 mb-5">
            <div
              class="w-10 h-10 lg:w-12 lg:h-12 rounded-xl bg-[#e0fcff] flex items-center justify-center text-[#00e5ff] shrink-0"
            >
              <svg
                class="w-5 h-5 lg:w-6 lg:h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.14 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"
                ></path>
              </svg>
            </div>
            <div>
              <h3
                class="font-[Orbitron] text-[13px] lg:text-sm font-bold text-gray-900 tracking-wider"
              >
                COMMS FREQUENCY
              </h3>
              <p
                class="font-[Space_Mono] text-[9px] lg:text-[10px] text-[#00e5ff] tracking-widest uppercase mt-0.5 font-bold"
              >
                ENCRYPTED CHANNEL 808.21
              </p>
            </div>
          </div>

          <div
            class="flex flex-col gap-2.5 font-[Space_Mono] text-[11px] lg:text-xs"
          >
            <div
              class="flex justify-between items-center pb-2.5 border-b border-gray-300/60"
            >
              <span class="text-gray-500 tracking-widest font-semibold"
                >VOICE:</span
              >
              <span class="font-bold text-gray-800 tracking-wider"
                >+1 (888) ROBO-SYNC</span
              >
            </div>
            <div class="flex justify-between items-center pt-0.5">
              <span class="text-gray-500 tracking-widest font-semibold"
                >STATUS:</span
              >
              <span
                class="font-bold text-[#10b981] flex items-center gap-2.5 tracking-wider"
              >
                <span
                  class="w-2 h-2 rounded-full bg-[#10b981] shadow-[0_0_8px_#10b981] flex shrink-0 relative"
                >
                  <span
                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#10b981] opacity-75"
                  ></span>
                </span>
                RECEIVING
              </span>
            </div>
          </div>
        </div>

        <!-- CARD 3 -->
        <div
          class="relative bg-white/70 backdrop-blur-md rounded-tr-lg rounded-bl-lg p-5 lg:p-6 border border-white/60 shadow-[0_15px_30px_-5px_rgba(0,0,0,0.08)]"
        >
          <div
            class="absolute -top-[3px] -left-[3px] w-4 h-4 border-t-[2px] border-l-[2px] border-[#00e5ff]/80 rounded-tl-sm pointer-events-none"
          >
          </div>
          <div
            class="absolute -bottom-[3px] -right-[3px] w-4 h-4 border-b-[2px] border-r-[2px] border-[#00e5ff]/80 rounded-br-sm pointer-events-none"
          >
          </div>

          <h3
            class="font-[Orbitron] text-[13px] lg:text-sm font-bold text-gray-900 tracking-wider mb-4"
          >
            SOCIAL UPLINK
          </h3>
          <div class="flex items-center justify-between gap-3">
            <a
              href="#"
              class="w-11 h-11 lg:w-12 lg:h-12 rounded-xl bg-[#f0f4f8]/80 text-[#00e5ff] flex items-center justify-center hover:bg-[#00e5ff] hover:text-white transition-all duration-300 shadow-sm hover:shadow-[0_5px_15px_rgba(0,229,255,0.4)] hover:-translate-y-1 pointer-events-auto"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="w-11 h-11 lg:w-12 lg:h-12 rounded-xl bg-[#f0f4f8]/80 text-[#00e5ff] flex items-center justify-center hover:bg-[#00e5ff] hover:text-white transition-all duration-300 shadow-sm hover:shadow-[0_5px_15px_rgba(0,229,255,0.4)] hover:-translate-y-1 pointer-events-auto"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="w-11 h-11 lg:w-12 lg:h-12 rounded-xl bg-[#f0f4f8]/80 text-[#00e5ff] flex items-center justify-center hover:bg-[#00e5ff] hover:text-white transition-all duration-300 shadow-sm hover:shadow-[0_5px_15px_rgba(0,229,255,0.4)] hover:-translate-y-1 pointer-events-auto"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="w-11 h-11 lg:w-12 lg:h-12 rounded-xl bg-[#f0f4f8]/80 text-[#00e5ff] flex items-center justify-center hover:bg-[#00e5ff] hover:text-white transition-all duration-300 shadow-sm hover:shadow-[0_5px_15px_rgba(0,229,255,0.4)] hover:-translate-y-1 pointer-events-auto"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                ></path><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
              >
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
