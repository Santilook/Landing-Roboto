---

---

<div
  id="contador-animado"
  class="w-full lg:w-90 xl:w-100 h-auto px-6 py-6 lg:px-10 bg-white/40 backdrop-blur-md rounded-2xl border border-white/60 shadow-xl lg:relative lg:bottom-16 xl:bottom-10 2xl:bottom-10"
>
  <div
    class="flex flex-col sm:flex-row gap-8 lg:gap-5 items-center lg:items-start text-center sm:text-left"
  >
    <div class="flex flex-col gap-1">
      <span
        id="counter-1"
        class="font-[Orbitron] text-3xl lg:text-2xl xl:text-3xl font-black text-gray-900 tracking-[-1px]"
      >
        +0%
      </span>
      <p
        class="font-[Space_Mono] text-[10px] lg:text-[11px]  text-cyan-600 tracking-[3px] uppercase font-bold"
      >
        Eficiencia Operativa
      </p>
    </div>

    <div
      class="hidden sm:block w-[1px] h-12 bg-gray-200"
      aria-hidden="true"
    >
    </div>

    <div class="flex flex-col gap-1">
      <span
        id="counter-2"
        class="font-[Orbitron] text-3xl lg:text-2xl xl:text-3xl font-black text-gray-900 tracking-[-1px]"
      >
        +0.00s
      </span>
      <p
        class="font-[Space_Mono] text-[10px] lg:text-[11px] text-cyan-600 tracking-[3px] uppercase font-bold"
      >
        Latencia de Respuesta
      </p>
    </div>
  </div>
</div>

<script>
  const container = document.getElementById("contador-animado");
  const counter1El = document.getElementById("counter-1");
  const counter2El = document.getElementById("counter-2");

  if (container && counter1El && counter2El) {
    let animated = false;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !animated) {
          animated = true;
          animateCounter(counter1El, 0, 99.9, 0.95, (v) => `+${v.toFixed(1)}%`);
          animateCounter(counter2El, 0, 0.3, 0.01, (v) => `+${v.toFixed(2)}s`);
          observer.disconnect();
        }
      },
      { threshold: 0.3 },
    );

    observer.observe(container);
  }

  function animateCounter(
    el: HTMLElement,
    from: number,
    to: number,
    step: number,
    format: (v: number) => string,
  ) {
    let current = from;
    const interval = setInterval(() => {
      current = Math.min(current + step, to);
      el.textContent = format(current);
      if (current >= to) clearInterval(interval);
    }, 40);
  }
</script>
