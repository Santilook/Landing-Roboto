---

---

<footer
  class="w-full relative z-30 bg-white/80 backdrop-blur-xl border-t border-gray-100 shadow-[0_-10px_40px_rgba(0,0,0,0.03)] mt-20"
>
  <div
    class="max-w-[1300px] mx-auto px-6 lg:px-10 py-10 lg:py-16 flex flex-col items-center justify-between gap-10 md:flex-row"
  >
    <!-- ── BLOQUE LÓGICO: Branding ── -->
    <div class="flex items-center gap-4 group">
      <div
        class="w-10 h-10 rounded-xl bg-cyan-50 flex items-center justify-center border border-cyan-100 text-cyan-500 group-hover:bg-cyan-500 group-hover:text-white transition-all duration-500 shadow-sm"
        aria-hidden="true"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      <div>
        <h2
          class="font-[Orbitron] text-xl font-black text-gray-900 tracking-[3px] m-0 leading-none flex items-center gap-2 uppercase"
        >
          <img
            src="/logo-R.svg"
            alt="Logo Nexus Robotics"
            class="w-6 h-6 opacity-90"
            style="filter: brightness(0);"
          />
          Oboto
        </h2>
        <p
          class="font-[Space_Mono] text-[9px] text-cyan-600 tracking-[4px] uppercase mt-1 font-black opacity-70"
        >
          Protocolo Activo
        </p>
      </div>
    </div>

    <!-- ── NAVEGACIÓN: Enlaces Secundarios ── -->
    <nav
      class="flex flex-wrap justify-center gap-x-8 gap-y-4 font-[Space_Mono] text-[11px] font-bold text-gray-500 tracking-widest uppercase"
      aria-label="Navegación de pie de página"
    >
      <a
        href="#modelos"
        class="hover:text-cyan-600 transition-colors duration-300">Modelos</a
      >
      <a
        href="#nosotros"
        class="hover:text-cyan-600 transition-colors duration-300">Nosotros</a
      >
      <a
        href="#contacto"
        class="hover:text-cyan-600 transition-colors duration-300">Contacto</a
      >
      <a
        href="#"
        class="hover:text-cyan-600 transition-colors duration-300 opacity-50"
        >Legal</a
      >
    </nav>

    <!-- ── INFORMACIÓN: Copyright y Estado ── -->
    <div class="text-center md:text-right space-y-1">
      <p
        class="font-[Space_Mono] text-[10px] text-gray-400 tracking-[2px] uppercase font-medium"
      >
        © 2026 Nexus Robotics Corp.
      </p>
      <p
        class="font-[Space_Mono] text-[9px] text-gray-300 tracking-[1px] uppercase"
      >
        Sincronización de datos completada.
      </p>
    </div>
  </div>

  <!-- ── ACENTO VISUAL: Gradiente Tecnológico ── -->
  <div
    class="w-full h-[2px] bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-30"
    aria-hidden="true"
  >
  </div>
</footer>
