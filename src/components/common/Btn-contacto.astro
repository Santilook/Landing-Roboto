---

---

<button
  type="submit"
  aria-label="Transmitir señal de contacto"
  class="mt-2 w-full cursor-pointer relative bg-cyan-500/10 py-3 rounded-xl min-h-[3.8rem] group flex items-center justify-start transition-all duration-[800ms] ease-[cubic-bezier(0.51,0.026,0.368,1.016)] shadow-[inset_0_0_15px_rgba(6,182,212,0.1)] hover:bg-cyan-600 border border-cyan-500/30 hover:shadow-[0_15px_30px_rgba(6,182,212,0.4)] pointer-events-auto"
>
  <!-- ── ELEMENTO VISUAL: Indicador de carga/transmisión ── -->
  <div
    class="absolute flex px-2 py-1.5 justify-start items-center inset-0 pointer-events-none"
  >
    <div
      class="w-[0%] group-hover:w-full transition-all duration-[1s] ease-[cubic-bezier(0.51,0.026,0.368,1.016)] bg-white/10 h-full rounded-lg"
    >
    </div>
    <div
      class="rounded-lg shrink-0 flex justify-center items-center h-full aspect-square bg-cyan-500 transition-all duration-[1s] ease-[cubic-bezier(0.51,0.026,0.368,1.016)] group-hover:bg-gray-900 shadow-lg shadow-cyan-500/20 group-hover:shadow-none"
    >
      <div
        class="size-[1.2rem] text-white group-hover:text-cyan-400 transition-all duration-[1s] ease-[cubic-bezier(0.51,0.026,0.368,1.016)]"
      >
        <svg
          class="w-full h-full"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="3"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
        </svg>
      </div>
    </div>
  </div>

  <!-- ── TEXTO DEL BOTÓN ── -->
  <span
    class="w-full text-center pl-[3.5rem] pr-[1.1rem] group-hover:pl-[1.1rem] group-hover:pr-[3.5rem] transition-all duration-[1s] ease-[cubic-bezier(0.51,0.026,0.368,1.016)] text-gray-800 group-hover:text-white font-[Orbitron] text-xs lg:text-sm font-black tracking-[3px] uppercase"
  >
    Transmitir Señal
  </span>
</button>
