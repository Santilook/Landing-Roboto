<!-- SECCIÓN 2: JEFES -->
<section
  id="jefes"
  class="w-full flex flex-col items-center justify-center px-10 py-15 pointer-events-none box-border relative z-20"
>
  <div
    class="w-full rounded-3xl px-10 py-20 bg-[#EFF0F1]  overflow-hidden"
    style={{
      backgroundImage:
        "linear-gradient(rgba(8,145,178,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(8,145,178,0.05) 1px, transparent 1px)",
      backgroundSize: "50px 50px",
    }}
  >
    <div class="text-center mb-16" style="pointer-events:auto;">
      <div class="flex items-center justify-center gap-3 mb-3">
        <span class="inline-block w-10 h-[3px] bg-cyan-600 rounded-sm"></span>
        <span class="font-[Orbitron] text-xs tracking-[6px] text-cyan-700">
          EQUIPO
        </span>
        <span class="inline-block w-10 h-[3px] bg-cyan-600 rounded-sm"></span>
      </div>
      <h2
        class="font-[Orbitron] text-[clamp(28px,4vw,48px)] font-bold text-gray-900 m-0 tracking-[4px]"
      >
        Nuestro Equipo
      </h2>
      <p class="font-[Rajdhani] text-lg text-gray-500 mt-3 tracking-[1px]">
        Los arquitectos detrás de la revolución robótica
      </p>
    </div>

    <div class="grid grid-cols-2 gap-x-16 gap-y-20 max-w-[1500px] mx-auto" style="pointer-events:auto;">
      {
        jefes.map((jefe, index) => {
          const isEven = index % 2 !== 0;
          return (
            <div
              class={`flex items-start gap-8 ${isEven ? "flex-row-reverse" : ""}`}
            >
              {/* FOTO */}
              <div class="jefe-photo-wrapper shrink-0">
                <div class="jefe-photo">
                  <img
                    src={jefe.imagen}
                    alt={jefe.nombre}
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>

              {/* INFO */}
              <div
                class={`flex flex-col gap-3 ${isEven ? "text-right items-end" : ""}`}
              >
                <span class="jefe-badge font-[Orbitron]">
                  ID: ARCH-0{jefe.id}
                </span>
                <h3 class="font-['Space_Mono'] text-3xl font-bold text-gray-900 leading-tight tracking-wide m-0">
                  {jefe.nombre}
                </h3>
                <div
                  class={`flex flex-col gap-1 font-['Space_Mono'] text-sm tracking-wider ${isEven ? "items-end" : ""}`}
                >
                  <p class="m-0">
                    <span class="text-gray-500">ROLE: </span>
                    <span class="text-[#00e5ff] font-bold">{jefe.rol}</span>
                  </p>
                  <p class="m-0">
                    <span class="text-gray-500">EDAD: </span>
                    <span class="text-[#00e5ff] font-bold">
                      {jefe.edad} AÑOS
                    </span>
                  </p>
                </div>
                <div class="flex gap-1.5 mt-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#00e5ff]" />
                  <span class="w-2.5 h-2.5 rounded-full bg-[#00e5ff] opacity-60" />
                  <span class="w-2.5 h-2.5 rounded-full bg-[#00e5ff] opacity-30" />
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const nosotrosSection = document.querySelector("inicio-sticky");
    const jefesSection = document.getElementById("jefes");

    if (nosotrosSection && jefesSection) {
      // Pin the nosotros section
      ScrollTrigger.create({
        trigger: nosotrosSection,
        start: "top top",
        end: "top top",
        pin: true,
        pinSpacing: false,
      });

      // Fade in jefes section as it scrolls up
      gsap.from(jefesSection, {
        opacity: 0,
        y: 60,
        duration: 1,
        scrollTrigger: {
          trigger: jefesSection,
          start: "top top",
          end: "top top",
          scrub: 1,
        },
      });
    }
  });
</script>
