---
import ContadorAnimado from "../ui/ContadorAnimado.astro"
---

<header class="relative overflow-hidden pointer-events-none">
  <div
    class="flex flex-col lg:min-h-screen z-50 relative initial-fade-in pointer-events-none"
  >
    <!-- [01] LOGOTIPO Y ENLACE SOCIAL -->
    <div>
      <div
        class="flex items-center justify-between lg:justify-start mx-6 lg:ml-7 my-6 2xl:mx-10 2xl:my-10"
      >
        <div class="flex items-center gap-3">
          <span
            class="bg-[#00e5ff] py-5 lg:py-5 xl:py-7 px-1.5 lg:px-2 rounded-full"
            aria-hidden="true"></span>
          <h1 class="text-4xl lg:text-4xl xl:text-5xl 2xl:text-6xl font-bold tracking-tighter">
            ROBOTO
          </h1>
        </div>

        <div class="lg:absolute lg:right-5 2xl:right-12 lg:top-6 2xl:top-10" style="pointer-events: visible;">
          <a
            href="https://github.com/Santilook"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Ver el perfil de GitHub del desarrollador"
            title="GitHub"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="36"
              height="36"
              class="lg:w-[44px] lg:h-[44px]"
              viewBox="0 0 24 24"
              role="img"
              aria-hidden="true"
            >
              <defs>
                <mask id="SVGcZ81hcNk">
                  <path
                    fill="#fff"
                    d="M9.5 8c0.83 0 1.5 0.45 1.5 1c0 0.55 -0.67 1 -1.5 1c-0.83 0 -1.5 -0.45 -1.5 -1c0 -0.55 0.67 -1 1.5 -1ZM14.5 8c0.83 0 1.5 0.45 1.5 1c0 0.55 -0.67 1 -1.5 1c-0.83 0 -1.5 -0.45 -1.5 -1c0 -0.55 0.67 -1 1.5 -1Z"
                  ></path>
                  <rect width="8" height="4" x="8" y="7">
                    <animate
                      attributeName="y"
                      dur="9s"
                      keyTimes="0;0.45;0.46;0.54;0.55;1"
                      repeatCount="indefinite"
                      values="7;7;11;11;7;7"></animate>
                  </rect>
                </mask>
              </defs>
              <g
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
              >
                <path
                  stroke-dasharray="32"
                  d="M12 4c1.67 0 2.61 0.4 3 0.5c0.53 -0.43 1.94 -1.5 3.5 -1.5c0.34 1 0.29 2.22 0 3c0.75 1 1 2 1 3.5c0 2.19 -0.48 3.58 -1.5 4.5c-1.02 0.92 -2.11 1.37 -3.5 1.5c0.65 0.54 0.5 1.87 0.5 2.5c0 0.73 0 3 0 3M12 4c-1.67 0 -2.61 0.4 -3 0.5c-0.53 -0.43 -1.94 -1.5 -3.5 -1.5c-0.34 1 -0.29 2.22 0 3c-0.75 1 -1 2 -1 3.5c0 2.19 0.48 3.58 1.5 4.5c1.02 0.92 2.11 1.37 3.5 1.5c-0.65 0.54 -0.5 1.87 -0.5 2.5c0 0.73 0 3 0 3"
                >
                  <animate
                    fill="freeze"
                    attributeName="stroke-dashoffset"
                    dur="0.6s"
                    values="32;0"></animate>
                </path>
                <path
                  stroke-dasharray="10"
                  stroke-dashoffset="10"
                  d="M9 19c-1.41 0 -2.84 -0.56 -3.69 -1.19c-0.84 -0.62 -1.09 -1.66 -2.31 -2.31"
                >
                  <animate
                    attributeName="d"
                    dur="3s"
                    keyTimes="0;0.5;1"
                    repeatCount="indefinite"
                    values="M9 19c-1.41 0 -2.84 -0.56 -3.69 -1.19c-0.84 -0.62 -1.09 -1.66 -2.31 -2.31;M9 19c-1.41 0 -3 -0.5 -4 -0.5c-0.53 0 -1 0 -2 -0.5;M9 19c-1.41 0 -2.84 -0.56 -3.69 -1.19c-0.84 -0.62 -1.09 -1.66 -2.31 -2.31"
                  ></animate>
                  <animate
                    fill="freeze"
                    attributeName="stroke-dashoffset"
                    begin="0.7s"
                    dur="0.2s"
                    to="0"></animate>
                </path>
              </g>
              <path
                fill="currentColor"
                d="M0 0h24v24H0z"
                mask="url(#SVGcZ81hcNk)"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- [02] TEXTO PRINCIPAL Y ACCIÓN -->
    <div class="lg:flex-1 flex items-center">
      <div class="flex flex-col gap-6 lg:gap-10 mx-6 2xl:mx-10 my-10 lg:mx-7 lg:max-w-[50%] xl:max-w-[55%] 2xl:max-w-[50%]">
        <h2
          class="text-3xl p-2 lg:bg-transparent lg:backdrop-blur-none lg:p-0 lg:text-3xl xl:text-4xl 2xl:text-5xl font-bold leading-tight uppercase tracking-tighter rounded-sm"
        >
          Más Allá de la Capacidad Humana.
        </h2>
        <div class="flex gap-4 lg:gap-0 2xl:gap-4">  
          <span
            class="bg-[#00e5ff] w-1.5 lg:w-2 min-h-[60px] rounded-full shrink-0"
            aria-hidden="true"></span>
          <p
            class="text-md font-semibold lg:text-md xl:text-lg 2xl:text-xl lg:h-full lg:w-100 2xl:w-150 leading-relaxed text-sky-200 lg:text-gray-500 bg-sky-900/30 backdrop-blur-md rounded-sm p-2 lg:p-5 lg:bg-transparent lg:backdrop-blur-none"
          >
            Presentamos la Serie X. Sistemas humanoides de ingeniería de
            precisión diseñados para la escala industrial y la compañía
            personal. Cada unidad está construida con inteligencia adaptativa,
            permitiéndoles aprender y evolucionar según tus necesidades.
          </p>
        </div>
        <a
          href="#modelos"
          class="bg-[#0f172b] text-white font-bold py-3 px-8 flex items-center gap-2 rounded-full w-fit cursor-pointer hover:scale-105 transition-all duration-300 shadow-lg shadow-cyan-500/20 pointer-events-auto"
          aria-label="Explorar nuestros modelos de robots"
        >
          Explora nuestros modelos
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M6.4 18L5 16.6L14.6 7H6V5h12v12h-2V8.4z"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- [03] CONTADOR ANIMADO -->
    <div class="px-6 xl:px-7 xl:py-5 2xl:px-10 py-10">
      <ContadorAnimado />
    </div>

    <!-- [04] NAVEGACIÓN (RESPONSIVE) -->
    <div
      id="nav-sentinel"
      class="px-6 relative z-[100]"
    >
      <nav
        id="main-nav"
        class="lg:fixed lg:right-4 lg:top-50 py-10 lg:py-0 transition-all duration-300 z-[100]"
        style="pointer-events: visible;"
      >
        <ul
          class="flex flex-row lg:flex-col justify-center lg:justify-end gap-5 lg:gap-5 lg:text-end backdrop-blur-sm lg:backdrop-blur-none p-4 rounded-full border border-white/10 lg:border-none transition-all"
        >
          <li class="flex items-center justify-end gap-2 lg:gap-5">
            <p class="hidden lg:block text-lg text-[#8d9497]">01</p>
            <a
              class="hover:text-cyan-400 transition-colors uppercase tracking-widest text-xs lg:text-lg 2xl:text-xl"
              href="/">Inicio</a
            >
          </li>
          <li class="flex items-center justify-end gap-2 lg:gap-5">
            <p class="hidden lg:block text-lg text-[#8d9497]">02</p>
            <a
              class="hover:text-cyan-400 transition-colors uppercase tracking-widest text-xs lg:text-lg 2xl:text-xl"
              href="#modelos">Modelos</a
            >
          </li>
          <li class="flex items-center justify-end gap-2 lg:gap-5">
            <p class="hidden lg:block text-lg text-[#8d9497]">03</p>
            <a
              class="hover:text-cyan-400 transition-colors uppercase tracking-widest text-xs lg:text-lg 2xl:text-xl"
              href="#nosotros">Nosotros</a
            >
          </li>
          <li class="flex items-center justify-end gap-2 lg:gap-5">
            <p class="hidden lg:block text-lg text-[#8d9497]">04</p>
            <a
              class="hover:text-cyan-400 transition-colors uppercase tracking-widest text-xs lg:text-lg 2xl:text-xl"
              href="#contacto">Contacto</a
            >
          </li>
        </ul>
      </nav>
    </div>

    <!-- [05] CARD INFO PRODUCTO -->
    <!-- En mobile: flujo normal después de la nav. En desktop: posicionado absoluto dentro del header -->
    <div
      class="px-6 lg:px-0 lg:absolute lg:top-[280px] lg:right-[180px] xl:top-[340px] xl:right-[200px] 2xl:top-[500px] 2xl:right-[200px] z-[60]"
    >
      <div
        class="p-6 lg:p-5 rounded-xl border border-[#00e5ff]/30 bg-black/40 backdrop-blur-xl w-full lg:w-70 2xl:w-100 mt-10 lg:mt-0 2xl:p-10"
        style="pointer-events: none;"
        role="region"
        aria-labelledby="unit-title"
      >
        <div class="flex flex-col gap-4 lg:gap-5">
          <h2
            id="unit-title"
            class="text-xl lg:text-xl 2xl:text-2xl font-bold text-white tracking-widest uppercase"
          >
            X-SERIES AONE
          </h2>
          <p class="text-xs lg:text-xs 2xl:text-sm text-gray-300 leading-relaxed">
            Descubre la nueva generación de robots humanoides. El X-SERIES AONE
            combina agilidad suprema con un núcleo cognitivo avanzado. Es capaz
            de integrarse en cualquier entorno.
          </p>
          <button
            class="bg-[#00e5ff] text-black rounded-full py-2.5 lg:py-3 px-8 font-bold cursor-pointer hover:scale-105 transition-all duration-300 hover:shadow-[0_0_20px_rgba(0,229,255,0.4)] pointer-events-auto"
            aria-label="Pre-comprar ahora el modelo X-SERIES AONE"
          >
            PRE-COMPRA AHORA
          </button>
        </div>
        <div class="flex justify-between mt-5 pt-4 border-t border-white/10">
          <p
            class="text-gray-500 text-[10px] tracking-widest uppercase font-bold"
          >
            Modelo
          </p>
          <p
            class="text-[#00e5ff] text-[10px] tracking-widest uppercase font-bold text-shadow-glow"
          >
            X-SERIES AONE
          </p>
        </div>
      </div>
    </div>

    <!-- [06] SCROLL INDICATOR (solo desktop, posicionado absoluto) -->
    <div class="hidden lg:block lg:absolute lg:bottom-30 xl:bottom-15 2xl:bottom-0 lg:left-1/2 lg:-translate-x-1/2">
      <div
        class="flex items-center justify-center"
        style="pointer-events: visible;"
      >
        <a
          href="#modelos"
          class="animate-bounce p-2"
          aria-label="Deslizar hacia abajo"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="44"
            height="44"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill="#00e5ff"
              d="m11.5 13.508l-1.766-1.766q-.14-.14-.334-.14t-.334.14t-.141.348t.14.34l2.389 2.39q.242.241.565.241t.565-.242l2.389-2.388q.14-.134.14-.341t-.14-.348t-.347-.14t-.341.14l-1.766 1.766V9.096q0-.212-.144-.356t-.357-.144t-.365.144t-.153.356zM12.003 21q-1.866 0-3.51-.708q-1.643-.709-2.859-1.924t-1.925-2.856T3 12.003t.709-3.51Q4.417 6.85 5.63 5.634t2.857-1.925T11.997 3t3.51.709q1.643.708 2.859 1.922t1.925 2.857t.709 3.509t-.708 3.51t-1.924 2.859t-2.856 1.925t-3.509.709M12 20q3.35 0 5.675-2.325T20 12t-2.325-5.675T12 4T6.325 6.325T4 12t2.325 5.675T12 20m0-8"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Manejo de la navegación fija en móvil/tablet
  const nav = document.getElementById("main-nav");
  const sentinel = document.getElementById("nav-sentinel");

  const checkScroll = () => {
    if (window.innerWidth < 1024 && nav && sentinel) {
      const rect = sentinel.getBoundingClientRect();
      // Si el centinela (la posición original) ha salido por la parte superior
      if (rect.top <= 0) {
        nav.classList.add("nav-fixed-active");
      } else {
        nav.classList.remove("nav-fixed-active");
      }
    } else if (nav) {
      nav.classList.remove("nav-fixed-active");
    }
  };

  window.addEventListener("scroll", checkScroll);
  window.addEventListener("resize", checkScroll);
</script>

<style>
  .text-shadow-glow {
    text-shadow: 0 0 10px rgba(0, 229, 255, 0.5);
  }

  /* Estilos para la navegación fija en móvil */
  .nav-fixed-active {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    padding: 0.75rem 0 !important;
    background: rgba(255, 255, 255, 0.85) !important;
    backdrop-filter: blur(12px) !important;
    border-bottom: 1px solid rgba(0, 229, 255, 0.2) !important;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
    margin: 0 !important;
    z-index: 9999 !important;
  }

  .nav-fixed-active ul {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    gap: 1.5rem !important;
  }

  /* Aseguramos que los enlaces sean legibles sobre el fondo claro */
  .nav-fixed-active a {
    color: #111827 !important;
    font-weight: 700 !important;
    font-size: 0.75rem !important;
  }

</style>
