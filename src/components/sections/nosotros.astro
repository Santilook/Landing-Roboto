---
import BtnContacto from "../common/Btn-contacto.astro";
import StripedPattern from "../magicui/StripedPattern.astro";
const jefes = [
  {
    id: 1,
    nombre: "DR. ELIAS VANCE",
    edad: 30,
    rol: "DISEÑADOR DE NÚCLEO DE IA",
    imagen: "/jefe1.webp",
  },
  {
    id: 2,
    nombre: "ANTONELLA CORTÉS",
    edad: 35,
    rol: "SÍNTESIS CINÉTICA",
    imagen: "/jefe2.webp",
  },
  {
    id: 3,
    nombre: "MARCUS THORNE",
    edad: 40,
    rol: "ARQUITECTO DE HARDWARE",
    imagen: "/jefe3.webp",
  },
  {
    id: 4,
    nombre: "ARIA ZHANG",
    edad: 28,
    rol: "ÉTICA Y CUMPLIMIENTO",
    imagen: "/jefe4.webp",
  },
];
---

<!-- SECCIÓN 1: NOSOTROS -->
<section
  id="nosotros"
  class="w-full flex flex-col items-center justify-center px-4 lg:px-10 py-10 lg:py-15 box-border relative z-10"
  aria-labelledby="nosotros-title"
>
  <div
    class="bg-[#EFF0F1] relative w-full rounded-2xl lg:rounded-3xl overflow-hidden p-6 lg:p-10"
  >
    <StripedPattern
      className="[mask-image:radial-gradient(400px_circle_at_center,white,transparent)] inset-0 z-0 absolute opacity-30 lg:opacity-100"
    />

    <!-- HEADER -->
    <header class="text-center mb-8 lg:mb-10 relative z-10">
      <div class="flex items-center justify-center gap-3 mb-3">
        <span
          class="inline-block w-8 lg:w-10 h-[2px] lg:h-[3px] bg-cyan-600 rounded-sm"
          aria-hidden="true"></span>
        <span
          class="font-[Orbitron] text-[10px] lg:text-xs tracking-[4px] lg:tracking-[6px] text-cyan-700 uppercase font-bold"
          >Identidad</span
        >
        <span
          class="inline-block w-8 lg:w-10 h-[2px] lg:h-[3px] bg-cyan-600 rounded-sm"
          aria-hidden="true"></span>
      </div>
      <h2
        id="nosotros-title"
        class="font-[Orbitron] text-3xl lg:text-[clamp(28px,4vw,48px)] font-bold text-gray-900 m-0 tracking-[2px] lg:tracking-[4px] uppercase"
      >
        Sobre Nosotros
      </h2>
      <p
        class="font-[Rajdhani] text-base lg:text-lg text-gray-500 mt-2 lg:mt-3 tracking-[1px]"
      >
        Los pioneros de la coexistencia robótica
      </p>
    </header>

    <!-- 4 CARDS EN FILA (Misión, Visión, Historia, Valores) -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10 items-stretch relative z-10"
    >
      <!-- [01] MISIÓN -->
      <article
        class="flex flex-col gap-4 border-l-4 border-[#00e5ff] bg-white/70 backdrop-blur-sm rounded-xl lg:rounded-2xl p-5 lg:p-6 shadow-xl transition-transform hover:scale-[1.01]"
      >
        <h3
          class="font-[Orbitron] text-sm lg:text-base font-bold text-gray-800 flex items-center gap-2 uppercase tracking-wider"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 48 48"
            aria-hidden="true"
          >
            <circle
              cx="24"
              cy="24"
              r="21.5"
              fill="none"
              stroke="#00e5ff"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"></circle>
            <circle
              cx="24"
              cy="24"
              r="15.659"
              fill="none"
              stroke="#00e5ff"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"></circle>
            <circle
              cx="24"
              cy="24"
              r="9.855"
              fill="none"
              stroke="#00e5ff"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"></circle>
          </svg>
          [01] Nuestra Misión
        </h3>
        <div class="p-3 bg-cyan-500/5 rounded-xl flex flex-col gap-3">
          <p
            class="text-cyan-800 font-bold text-xs lg:text-sm leading-relaxed uppercase tracking-tighter"
          >
            [DESCIFRANDO...] Forjar el estándar de robótica autónoma global.
          </p>
          <p class="text-gray-600 text-xs lg:text-sm leading-relaxed">
            Nuestra misión es transformar el mundo a través de la tecnología,
            ofreciendo soluciones innovadoras y de alta calidad. Nos
            especializamos en la creación de inteligencias artificiales
            adaptativas.
          </p>
        </div>
      </article>

      <!-- [02] VISIÓN -->
      <article
        class="flex flex-col gap-4 border-l-4 border-[#00e5ff] bg-white/70 backdrop-blur-sm rounded-xl lg:rounded-2xl p-5 lg:p-6 shadow-xl transition-transform hover:scale-[1.01]"
      >
        <h3
          class="font-[Orbitron] text-sm lg:text-base font-bold text-gray-800 flex items-center gap-2 uppercase tracking-wider"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 14 14"
            aria-hidden="true"
          >
            <path
              fill="none"
              stroke="#00e5ff"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9.933 13.092a56 56 0 0 0 2.016-.234a.99.99 0 0 0 .854-.861c.08-.643.159-1.312.223-1.997M4.068.908a56 56 0 0 0-2.016.234a.99.99 0 0 0-.855.86A66 66 0 0 0 .974 4M9.933.908c.69.066 1.365.148 2.016.234a.99.99 0 0 1 .854.86c.08.644.159 1.313.223 1.998m-8.958 9.092a59 59 0 0 1-2.016-.234a.99.99 0 0 1-.855-.861A66 66 0 0 1 .974 10M7 5.162V3.877m0 1.285c.787 0 1.604 0 2.329.094a1.406 1.406 0 0 1 1.216 1.184c.059.403.059.812.059 1.508c0 .697 0 1.106-.06 1.508A1.406 1.406 0 0 1 9.33 10.64c-.725.095-1.542.095-2.329.095c-.786 0-1.603 0-2.328-.095a1.406 1.406 0 0 1-1.216-1.184c-.059-.402-.059-.811-.059-1.508s0-1.105.059-1.508a1.406 1.406 0 0 1 1.216-1.184c.725-.094 1.542-.094 2.328-.094m1.296 2.98v-.388M5.7 8.142v-.388M7 3.864c.616 0 .963-.347.963-.963S7.616 1.94 7 1.94s-.962.347-.962.962s.347.963.962.963"
              stroke-width="1"></path>
          </svg>
          [02] Nuestra Visión
        </h3>
        <div class="p-3 bg-cyan-500/5 rounded-xl flex flex-col gap-3 relative">
          <p
            class="text-cyan-800 font-bold text-sm leading-relaxed uppercase tracking-tighter"
          >
            [PROYECCIÓN...] Armonía total entre humanos y máquinas.
          </p>
          <p class="text-gray-600 text-xs lg:text-sm leading-relaxed">
            Aspiramos a democratizar el acceso a la robótica avanzada,
            desarrollando androides éticos y eficientes que potencian las
            capacidades humanas.
          </p>
        </div>
      </article>

      <!-- [03] HISTORIA -->
      <article
        class="flex flex-col gap-4 border-l-4 border-[#00e5ff] bg-white/70 backdrop-blur-sm rounded-xl lg:rounded-2xl p-5 lg:p-6 shadow-xl transition-transform hover:scale-[1.01]"
      >
        <h3
          class="font-[Orbitron] text-sm lg:text-base font-bold text-gray-800 flex items-center gap-2 uppercase tracking-wider"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <g
              fill="none"
              stroke="#00e5ff"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
            >
              <path
                d="m9.25 18.876l-6.512-4.682m3.002-2.673l5.143 3.813M.751 11.751a2.5 2.5 0 1 0 5 0a2.5 2.5 0 0 0-5 0m4.886-.746l5.611-5.465m-.856-3.962L1.257 10.25m8.492-7a2.5 2.5 0 1 0 5 0a2.5 2.5 0 0 0-5 0m6.545 4.132l-2.3-2.35m1.756 3.719a2 2 0 1 0 4 0a2 2 0 0 0-4 0"
              ></path>
              <path
                d="M19.7 8.3a3 3 0 0 1 3.55 2.951m-3 3A3 3 0 0 1 17.3 10.7M1 23.251h22m-13.75 0V18a3 3 0 0 1 6 0v5.25"
              ></path>
            </g>
          </svg>
          [03] Nuestra Historia
        </h3>
        <div class="p-3 bg-cyan-500/5 rounded-xl flex flex-col gap-3">
          <p
            class="text-cyan-800 font-bold text-sm leading-relaxed uppercase tracking-tighter"
          >
            [ARCHIVO...] Fundada en 2032 tras el Dr. Vance.
          </p>
          <p class="text-gray-600 text-xs lg:text-sm leading-relaxed">
            Comenzamos como un laboratorio de bioingeniería algorítmica.
            Logramos sintetizar el primer núcleo cognitivo autónomo hacia la
            generación cero.
          </p>
        </div>
      </article>

      <!-- [04] VALORES -->
      <article
        class="flex flex-col gap-4 border-l-4 border-[#00e5ff] bg-white/70 backdrop-blur-sm rounded-xl lg:rounded-2xl p-5 lg:p-6 shadow-xl transition-transform hover:scale-[1.01]"
      >
        <h3
          class="font-[Orbitron] text-sm lg:text-base font-bold text-gray-800 flex items-center gap-2 uppercase tracking-wider"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 48 48"
            aria-hidden="true"
          >
            <path
              fill="none"
              stroke="#00e5ff"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M22.873 21.466a1.282 1.282 0 0 0-.995 2.091l2.055 2.413l2.035-2.389l.01-.011l.01-.013a1.283 1.283 0 1 0-2.055-1.53a1.28 1.28 0 0 0-1.058-.56z"
              stroke-width="1"></path>
            <g
              fill="none"
              stroke="#00e5ff"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1"
            >
              <path
                d="M37.855 22.76a.942.942 0 1 1-1.885 0a.942.942 0 0 1 1.885 0m-4.711 0a.942.942 0 1 1-1.885 0a.942.942 0 0 1 1.885 0"
              ></path>
              <path
                d="m29.375 16.164l3.769 3.769h2.826l3.77-3.77v12.25H29.374zm-1.178 10.364h2.355m-2.355-1.413h2.355m8.009 1.413h2.356m-2.356-1.413h2.356m-6.36.941v-1.23m0 1.23l-.744.923m-.333-1.599l1.077.676m0 0l.743.923m.334-1.599l-1.077.676m-3.77 5.056a.942.942 0 1 1 0-1.632m5.18 1.632a.942.942 0 1 1 0-1.632m-4.239 1.757h1.885m3.297 0h1.884m.941 0h1.885m.942-4.761s.938 1.067.938 2.38s-.938 2.38-.938 2.38"
              ></path>
            </g>
          </svg>
          [04] Nuestros Valores
        </h3>
        <div class="p-3 bg-cyan-500/5 rounded-xl flex flex-col gap-3">
          <p
            class="text-cyan-800 font-bold text-sm leading-relaxed uppercase tracking-tighter"
          >
            [ÉTICA_CENTRAL...] Integridad y transparencia absoluta.
          </p>
          <p class="text-gray-600 text-xs lg:text-sm leading-relaxed">
            Diseño centrado en las personas y respeto incondicional por las
            leyes de la robótica. Garantizamos que la tecnología proteja a la
            humanidad.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- SECCIÓN 2: EQUIPO -->
<section
  id="equipo"
  class="w-full flex flex-col items-center justify-center px-4 lg:px-10 py-10 lg:py-15 box-border relative z-20"
  aria-labelledby="equipo-title"
>
  <div
    class="bg-[#EFF0F1] relative w-full rounded-2xl lg:rounded-3xl overflow-hidden p-6 lg:p-10 pb-16 lg:pb-20 shadow-[0_-20px_50px_rgba(0,0,0,0.15)]"
  >
    <StripedPattern
      className="[mask-image:radial-gradient(400px_circle_at_center,white,transparent)] inset-0 z-0 absolute opacity-30 lg:opacity-100"
    />

    <header class="text-center relative z-10 mb-12">
      <div class="flex items-center justify-center gap-3 mb-3">
        <span
          class="inline-block w-8 lg:w-10 h-[2px] lg:h-[3px] bg-cyan-600 rounded-sm"
          aria-hidden="true"></span>
        <span
          class="font-[Orbitron] text-[10px] lg:text-xs tracking-[4px] lg:tracking-[6px] text-cyan-700 uppercase font-bold"
        >
          Red Humana
        </span>
        <span
          class="inline-block w-8 lg:w-10 h-[2px] lg:h-[3px] bg-cyan-600 rounded-sm"
          aria-hidden="true"></span>
      </div>
      <h2
        id="equipo-title"
        class="font-[Orbitron] text-3xl lg:text-[clamp(28px,4vw,48px)] font-bold text-gray-900 m-0 tracking-[2px] lg:tracking-[4px] uppercase"
      >
        Nuestro Equipo
      </h2>
      <p
        class="font-[Rajdhani] text-base lg:text-lg text-gray-500 mt-2 lg:mt-3 tracking-[1px]"
      >
        Los cerebros que orquestan la singularidad
      </p>
    </header>

    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-x-16 lg:gap-y-20 max-w-[1500px] mx-auto relative z-10"
    >
      {
        jefes.map((jefe, index) => {
          const isEven = index % 2 !== 0;
          return (
            <article
              class={`flex flex-col sm:flex-row items-center sm:items-start gap-6 lg:gap-8 ${isEven ? "lg:flex-row-reverse" : ""}`}
            >
              {/* FOTO */}
              <div class="jefe-photo-wrapper shrink-0">
                <div class="jefe-photo border-2 border-cyan-400/20 rounded-2xl overflow-hidden aspect-square h-48 lg:h-56">
                  <img
                    src={jefe.imagen}
                    alt={`Retrato del arquitecto ${jefe.nombre}`}
                    class="w-full h-full object-cover transition-all duration-500"
                    loading="lazy"
                    width="224"
                    height="224"
                  />
                </div>
              </div>

              {/* INFO */}
              <div
                class={`flex flex-col gap-2 lg:gap-3 text-center sm:text-left ${isEven ? "lg:text-right lg:items-end" : ""}`}
              >
                <div class="flex flex-col gap-1">
                  <span class="font-[Orbitron] text-[10px] text-cyan-500 tracking-widest font-bold">
                    ID: ARCH-0{jefe.id}
                  </span>
                  <h3 class="font-['Space_Mono'] text-2xl lg:text-3xl font-black text-gray-900 leading-tight tracking-wide m-0 italic">
                    {jefe.nombre}
                  </h3>
                </div>

                <div
                  class={`flex flex-col gap-1 font-['Space_Mono'] text-xs lg:text-sm tracking-widest ${isEven ? "lg:items-end" : ""}`}
                >
                  <p class="m-0 uppercase">
                    <span class="text-[#00e5ff] font-bold">Rol: </span>
                    <span class="text-gray-500">{jefe.rol}</span>
                  </p>
                  <p class="m-0 uppercase">
                    <span class="text-[#00e5ff] font-bold">Edad: </span>
                    <span class="text-gray-500">{jefe.edad} Ciclos</span>
                  </p>
                </div>
                <div class="flex gap-1.5 mt-2 justify-center sm:justify-start">
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-[#00e5ff]"
                    aria-hidden="true"
                  />
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-[#00e5ff] opacity-60"
                    aria-hidden="true"
                  />
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-[#00e5ff] opacity-30"
                    aria-hidden="true"
                  />
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initAnimations() {
    const nosotrosSection = document.getElementById("nosotros");
    const equipoSection = document.getElementById("equipo");

    if (!nosotrosSection || !equipoSection) return;

    // Solo habilitar el pinning y animación compleja en pantallas grandes
    if (window.innerWidth > 1024) {
      ScrollTrigger.create({
        trigger: nosotrosSection,
        start: "top top",
        end: () => `+=${equipoSection.offsetHeight}`,
        pin: true,
        pinSpacing: false,
      });

      gsap.fromTo(
        equipoSection,
        { y: 80, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          ease: "power2.out",
          scrollTrigger: {
            trigger: equipoSection,
            start: "top 90%",
            end: "top 20%",
            scrub: 1.5,
          },
        },
      );
    } else {
      // En mobile, simplemente animar la entrada normal de las secciones
      gsap.from(nosotrosSection.children, {
        opacity: 0,
        y: 30,
        duration: 0.8,
        stagger: 0.2,
        scrollTrigger: {
          trigger: nosotrosSection,
          start: "top 80%",
        },
      });

      gsap.from(equipoSection.children, {
        opacity: 0,
        y: 30,
        duration: 0.8,
        stagger: 0.2,
        scrollTrigger: {
          trigger: equipoSection,
          start: "top 80%",
        },
      });
    }
  }

  document.addEventListener("DOMContentLoaded", initAnimations);

  // Re-inicializar con debounce al cambiar tamaño (evita lag en mobile)
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      ScrollTrigger.getAll().forEach((st) => st.kill());
      initAnimations();
    }, 300);
  });
</script>

<style>
  .jefe-photo-wrapper {
    perspective: 1000px;
  }
  .jefe-photo {
    transform: rotateY(-5deg);
    transition: transform 0.5s ease;
  }
  .jefe-photo-wrapper:hover .jefe-photo {
    transform: rotateY(0deg);
  }
</style>
