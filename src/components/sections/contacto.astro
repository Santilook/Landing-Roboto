---
import BtnContacto from "../common/Btn-contacto.astro";
import { Globe } from "../magicui/globe.tsx";

// src/components/contacto.astro

const social = [
  {
    name: "GitHub",
    url: "https://github.com/Santilook",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>`,
  },
  {
    name: "Twitter",
    url: "https://twitter.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768m2.46-2.46l6.772-6.772"></path></svg>`,
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/fullstacksantiago/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 2a2 2 0 1 1-2 2 2 2 0 0 1 2-2z"></path></svg>`,
  },
  {
    name: "Instagram",
    url: "https://instagram.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`,
  },
];
---

<section
  id="contacto"
  class="w-full flex flex-col items-center justify-center px-6 lg:px-10 py-16 lg:py-24 box-border relative z-30 pointer-events-none"
  aria-labelledby="contact-heading"
>
  <div class="w-full max-w-[1300px] mx-auto">
    <!-- ── ENCABEZADO ── -->
    <header class="mb-10 lg:mb-14 pointer-events-auto text-center lg:text-left">
      <h2
        id="contact-heading"
        class="font-[Orbitron] text-[clamp(26px,5vw,42px)] font-bold text-gray-900 m-0 uppercase tracking-widest flex flex-wrap items-center justify-center lg:justify-start gap-3"
      >
        Establecer <span
          class="text-cyan-500 drop-shadow-[0_0_15px_rgba(6,182,212,0.3)]"
          >Conexión</span
        >
      </h2>
      <p
        class="font-[Space_Mono] text-[10px] lg:text-xs text-gray-500 tracking-[4px] lg:tracking-[6px] uppercase mt-3 font-bold opacity-80"
      >
        Interconectando con la red neuronal de soporte Nexus
      </p>
    </header>

    <!-- ── CONTENEDOR PRINCIPAL: Grid Proporcional ── -->
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-8 relative items-stretch"
    >
      <!-- COLUMNA: FORMULARIO DE CONTACTO -->
      <article class="col-span-1 lg:col-span-5 relative z-10">
        <div
          class="relative w-full bg-white/80 backdrop-blur-2xl border border-white/40 rounded-2xl p-8 lg:p-10 shadow-2xl"
        >
          {/* Marcadores decorativos tecnológicos (Brackets) */}
          <div
            class="absolute -top-1 -left-1 w-6 h-6 border-t-2 border-l-2 border-cyan-500 rounded-tl-lg"
            aria-hidden="true"
          >
          </div>
          <div
            class="absolute -bottom-1 -right-1 w-6 h-6 border-b-2 border-r-2 border-cyan-500 rounded-br-lg"
            aria-hidden="true"
          >
          </div>

          <form class="flex flex-col gap-8">
            <!-- Campo: Nombre -->
            <div class="flex flex-col gap-2.5 pointer-events-auto">
              <label
                for="subject-name"
                class="font-[Orbitron] text-cyan-600 text-[9px] lg:text-[10px] font-black tracking-[3px] uppercase"
              >
                Identificación del Sujeto
              </label>
              <div
                class="relative flex items-center bg-gray-50 border border-gray-100 rounded-xl focus-within:border-cyan-400 focus-within:bg-white transition-all shadow-sm"
              >
                <div class="absolute left-4 text-cyan-500" aria-hidden="true">
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    ></path>
                  </svg>
                </div>
                <input
                  id="subject-name"
                  type="text"
                  required
                  placeholder="Ej: John Nexus"
                  class="w-full bg-transparent py-4 pl-12 pr-4 font-[Space_Mono] text-gray-800 text-sm focus:outline-none placeholder-gray-400 font-bold"
                />
              </div>
            </div>

            <!-- Campo: Correo Electrónico -->
            <div class="flex flex-col gap-2.5 pointer-events-auto">
              <label
                for="neural-id"
                class="font-[Orbitron] text-cyan-600 text-[9px] lg:text-[10px] font-black tracking-[3px] uppercase"
              >
                ID Neuronal (E-Mail)
              </label>
              <div
                class="relative flex items-center bg-gray-50 border border-gray-100 rounded-xl focus-within:border-cyan-400 focus-within:bg-white transition-all shadow-sm"
              >
                <div class="absolute left-4 text-cyan-500" aria-hidden="true">
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                </div>
                <input
                  id="neural-id"
                  type="email"
                  required
                  placeholder="usuario@red.nexus"
                  class="w-full bg-transparent py-4 pl-12 pr-4 font-[Space_Mono] text-gray-800 text-sm focus:outline-none placeholder-gray-400 font-bold"
                />
              </div>
            </div>

            <!-- Campo: Tipo de Protocolo -->
            <div class="flex flex-col gap-2.5 pointer-events-auto">
              <label
                for="protocol-type"
                class="font-[Orbitron] text-cyan-600 text-[9px] lg:text-[10px] font-black tracking-[3px] uppercase"
              >
                Protocolo de Enlace
              </label>
              <div
                class="relative flex items-center bg-gray-50 border border-gray-100 rounded-xl focus-within:border-cyan-400 focus-within:bg-white transition-all shadow-sm"
              >
                <div class="absolute left-4 text-cyan-500" aria-hidden="true">
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <select
                  id="protocol-type"
                  class="w-full bg-transparent py-4 pl-12 pr-10 font-[Space_Mono] text-gray-800 text-sm focus:outline-none appearance-none font-bold cursor-pointer"
                >
                  <option value="technical">CONSULTA TÉCNICA</option>
                  <option value="sales">PROTOCOLO DE ADQUISICIÓN</option>
                  <option value="support">DIAGNÓSTICO DEL SISTEMA</option>
                </select>
                <svg
                  class="absolute right-4 w-4 h-4 text-gray-400 pointer-events-none"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="3"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 9l-7 7-7-7"></path>
                </svg>
              </div>
            </div>

            <!-- Campo: Mensaje -->
            <div class="flex flex-col gap-2.5 pointer-events-auto">
              <label
                for="transmission-details"
                class="font-[Orbitron] text-cyan-600 text-[9px] lg:text-[10px] font-black tracking-[3px] uppercase"
              >
                Detalles de Transmisión
              </label>
              <div
                class="relative bg-gray-50 border border-gray-100 rounded-xl focus-within:border-cyan-400 focus-within:bg-white transition-all shadow-sm"
              >
                <textarea
                  id="transmission-details"
                  rows="4"
                  placeholder="Iniciando transferencia de datos..."
                  class="w-full bg-transparent py-4 px-5 font-[Space_Mono] text-gray-800 text-sm focus:outline-none placeholder-gray-400 resize-none font-bold"
                ></textarea>
              </div>
            </div>

            <!-- Botón -->
            <div class="pt-4">
              <BtnContacto />
            </div>
          </form>
        </div>
      </article>

      <!-- SEPARADOR: Espacio visual en Desktop -->
      <div class="hidden lg:block lg:col-span-2" aria-hidden="true"></div>

      <!-- COLUMNA: INFORMACIÓN DE CONTACTO / HUD RED -->
      <aside
        class="col-span-1 lg:col-span-5 flex flex-col gap-6 relative z-10 w-full"
      >
        <!-- Tarjeta: Coordenadas (Globo) -->
        <div
          class="bg-white/90 backdrop-blur-xl rounded-2xl p-6 border border-white/50 shadow-xl overflow-hidden group"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="w-12 h-12 rounded-xl bg-cyan-50 flex items-center justify-center text-cyan-500 border border-cyan-100 transition-colors group-hover:bg-cyan-500 group-hover:text-white"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3
                class="font-[Orbitron] text-sm font-black text-gray-900 tracking-wider uppercase"
              >
                Matriz de Comando
              </h3>
              <p
                class="font-[Space_Mono] text-[9px] text-cyan-600 tracking-widest uppercase font-bold"
              >
                Geo-Sync: 37.77 N, 122.41 W
              </p>
            </div>
          </div>

          {/* Contenedor del Globo */}
          <div
            class="w-full h-48 lg:h-60 bg-gray-900 rounded-xl overflow-hidden border border-gray-800 relative shadow-inner"
          >
            <div class="absolute inset-0 z-0 opacity-40 pointer-events-none">
              <div
                class="w-full h-full"
                style="background-image: radial-gradient(circle at 2px 2px, rgba(6,182,212,0.1) 1px, transparent 0); background-size: 20px 20px;"
                aria-hidden="true"
              >
              </div>
            </div>
            <div
              class="relative w-full h-[600px] -top-[150px] pointer-events-auto"
            >
              <Globe client:visible />
            </div>
          </div>
        </div>

        <!-- Tarjeta: Frecuencia (Comunicación) -->
        <div
          class="bg-white/90 backdrop-blur-xl rounded-2xl p-6 border border-white/50 shadow-xl group"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="w-12 h-12 rounded-xl bg-cyan-50 flex items-center justify-center text-cyan-500 border border-cyan-100 transition-colors group-hover:bg-cyan-500 group-hover:text-white"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.14 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"
                ></path>
              </svg>
            </div>
            <div>
              <h3
                class="font-[Orbitron] text-sm font-black text-gray-900 tracking-wider uppercase"
              >
                Canal de Enlace
              </h3>
              <p
                class="font-[Space_Mono] text-[9px] text-cyan-600 tracking-widest uppercase font-bold"
              >
                Frecuencia: 808.21 MHZ Encriptado
              </p>
            </div>
          </div>

          <div class="space-y-4 font-[Space_Mono] text-xs">
            <div
              class="flex justify-between items-center pb-3 border-b border-gray-100"
            >
              <span class="text-gray-400 font-bold tracking-widest uppercase"
                >Voz:</span
              >
              <span
                class="font-bold text-gray-800 tracking-tighter italic lg:tracking-normal lg:not-italic"
              >
                +1 (888) ROBO-SYNC
              </span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-400 font-bold tracking-widest uppercase"
                >Estatus:</span
              >
              <span
                class="font-bold text-emerald-500 flex items-center gap-2 tracking-widest"
              >
                <span class="relative flex h-2.5 w-2.5">
                  <span
                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
                  ></span>
                  <span
                    class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"
                  ></span>
                </span>
                Recibiendo
              </span>
            </div>
          </div>
        </div>

        <!-- Tarjeta: Redes Sociales -->
        <div
          class="bg-gray-900 rounded-2xl p-6 border border-gray-800 shadow-2xl"
        >
          <h3
            class="font-[Orbitron] text-[10px] font-black text-gray-400 tracking-[4px] uppercase mb-5 text-center lg:text-left"
          >
            Nodos Sociales
          </h3>
          <div
            class="flex flex-wrap items-center justify-center lg:justify-between gap-4 pointer-events-auto"
          >
            {
              social.map((node) => (
                <a
                  href={node.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Enlace a nodo ${node.name}`}
                  class="w-12 h-12 rounded-xl bg-gray-800/50 text-cyan-400 border border-gray-700 flex items-center justify-center hover:bg-cyan-500 hover:text-white hover:border-cyan-400 transition-all duration-300 shadow-lg hover:shadow-cyan-500/25 hover:-translate-y-1"
                >
                  <Fragment set:html={node.icon} />
                </a>
              ))
            }
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
